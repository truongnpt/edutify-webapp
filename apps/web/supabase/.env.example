# Copy to .env in this folder (supabase/.env is gitignored).
# Create OAuth 2.0 credentials in Google Cloud Console (Web application).
#
# In Google Cloud → Credentials → OAuth 2.0 Client (Web) → Authorized redirect URIs, add EXACTLY:
#   http://127.0.0.1:55521/auth/v1/callback
# (If you use localhost for the API in .env instead, add http://localhost:55521/auth/v1/callback and
# set redirect_uri in config.toml to match.)
#
# Authorized JavaScript origins (optional): http://localhost:3000 and/or http://127.0.0.1:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
